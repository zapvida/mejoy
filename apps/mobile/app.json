{
  "expo": {
    "name": "MeJoy",
    "slug": "mejoy-native",
    "scheme": "mejoy",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "experiments": {
      "typedRoutes": true
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "color": "#167C5A",
          "mode": "production"
        }
      ],
      [
        "expo-document-picker",
        {
          "iCloudContainerEnvironment": "Production"
        }
      ]
    ],
    "ios": {
      "bundleIdentifier": "br.com.mejoy.app",
      "supportsTablet": true,
      "associatedDomains": [
        "applinks:mejoy.com.br",
        "applinks:www.mejoy.com.br"
      ],
      "infoPlist": {
        "NSCameraUsageDescription": "A MeJoy usa a câmera para ler cardápios, refeições e exames do paciente.",
        "NSPhotoLibraryUsageDescription": "A MeJoy acessa sua galeria para anexar refeições, exames e documentos clínicos.",
        "NSPhotoLibraryAddUsageDescription": "A MeJoy salva comprovantes e conteúdos compartilháveis quando você solicitar.",
        "NSHealthShareUsageDescription": "A MeJoy lê sono, passos e métricas compartilhadas para personalizar o coaching de saúde.",
        "NSHealthUpdateUsageDescription": "A MeJoy grava apenas dados necessários quando você optar por sincronizar sua jornada.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "br.com.mejoy.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.POST_NOTIFICATIONS",
        "android.permission.READ_MEDIA_IMAGES",
        "android.permission.READ_MEDIA_VISUAL_USER_SELECTED",
        "android.permission.VIBRATE"
      ],
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "mejoy.com.br",
              "pathPrefix": "/"
            },
            {
              "scheme": "https",
              "host": "www.mejoy.com.br",
              "pathPrefix": "/"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ],
      "versionCode": 2
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "ca40b9f0-234c-485f-9c25-500728c89794"
      }
    },
    "owner": "allzapvida",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/ca40b9f0-234c-485f-9c25-500728c89794"
    }
  }
}
