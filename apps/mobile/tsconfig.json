{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "strict": true,
    "jsx": "react-jsx",
    "moduleResolution": "bundler",
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["react", "react-native"],
    "paths": {
      "@/*": ["./src/*"],
      "@mejoy/api-contracts": ["../../packages/api-contracts/src/index.ts"],
      "@mejoy/api-contracts/*": ["../../packages/api-contracts/src/*"],
      "@mejoy/design-tokens": ["../../packages/design-tokens/src/index.ts"],
      "@mejoy/design-tokens/*": ["../../packages/design-tokens/src/*"]
    }
  },
  "include": ["app/**/*.ts", "app/**/*.tsx", "src/**/*.ts", "src/**/*.tsx", ".expo/types/**/*.ts", "expo-env.d.ts"]
}
