# Alloe Health - Production Environment Configuration
# This file contains the production environment variables

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_production_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_production_service_role_key

# Database Configuration
DATABASE_URL="postgresql://prod_user:prod_password@db.your-project.supabase.co:5432/postgres?pgbouncer=true&connection_limit=1"

# OpenAI Configuration
OPENAI_API_KEY="sk-prod-your-openai-key-here"

# Next.js Configuration
NEXTAUTH_SECRET="your-production-nextauth-secret-here"
NEXTAUTH_URL="https://alloehealth.com"

# Stripe Configuration
STRIPE_SECRET_KEY="sk_live_your-stripe-secret-key-here"
STRIPE_PUBLIC_KEY="pk_live_your-stripe-public-key-here"
STRIPE_WEBHOOK_SECRET="whsec_your_webhook_secret"

# Production Configuration
NODE_ENV="production"
NEXT_PUBLIC_APP_URL="https://alloehealth.com"
NEXT_PUBLIC_APP_NAME="Alloe Health"

# WhatsApp Integration
WHATSAPP_API_URL="https://api.whatsapp.com"
WHATSAPP_PHONE="+5547999009923"

# High Level Integration
HIGHLEVEL_API_KEY="your-production-highlevel-api-key"
HIGHLEVEL_LOCATION_ID="your-production-location-id"

# Asaas Integration
ASAAS_API_KEY="aact_prod_your_asaas_key"
WEBHOOK_ASAAS_URL="https://alloehealth.com/api/asaasWebhook"
