# ZapFarm - Variáveis de Ambiente Local
# Copie este arquivo para .env.local e configure com seus valores reais

# ==== Database ====
DATABASE_URL="postgresql://your_user:your_password@your_host:5432/your_database"

# ==== IA ====
OPENAI_API_KEY="your_secret_from_provider"
MOCK_AI="0"
AI_REPORT_ENABLED="1"

# ==== NextAuth ====
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_secret_from_provider"

# ==== Analytics ====
NEXT_PUBLIC_GA4_MEASUREMENT_ID="G-XXXXXXXXXX"
VERCEL_TOKEN="your_secret_from_provider"

# ==== Core Configuration ====
NEXT_PUBLIC_BASE_URL=https://www.zapfarm.com.br
B2B_ENABLED=1
DEFAULT_TENANT=zapfarm
LOG_LEVEL=info

# ==== Stripe Configuration ====
STRIPE_SECRET_KEY="your_secret_from_provider"
STRIPE_WEBHOOK_SECRET="your_secret_from_provider"

# Stripe Prices - Troque pelos seus price IDs reais
STRIPE_PRICE_PLUS_MONTHLY="price_******************"
STRIPE_PRICE_PLUS_YEARLY="price_******************"
STRIPE_PRICE_GIFT_MONTHLY="price_*****************"
STRIPE_PRICE_GIFT_YEARLY="price_******************"
STRIPE_PRICE_ADDON_MONTHLY="price_****************"
STRIPE_PRICE_ADDON_YEARLY="price_*****************"

# ==== GHL CRM Integration ====
GHL_API_KEY="****************************************"
GHL_LOCATION_ID="***********************************"
GHL_PIPELINE_ID="***********************************"
GHL_STAGE_VISIT="***********************************"
GHL_STAGE_TRIAGE="**********************************"
GHL_STAGE_CHECKOUT="********************************"
GHL_STAGE_WON="*************************************"

# ==== Rate-limit / Idempotência ====
UPSTASH_REDIS_REST_URL="https://*********.upstash.io"
UPSTASH_REDIS_REST_TOKEN="**************************"

# ==== Flags opcionais / integrações ====
SUPABASE_SERVICE_ROLE_KEY=""
STRIPE_PRICE_ALL_ACCESS=""
STRIPE_PRICE_GIFT=""
META_CONVERSIONS_API_ACCESS_TOKEN=""
ASAAS_API_KEY=""
WEBHOOK_ASAAS_URL=""

# ==== Feature Flags GI Enhanced ====
NEXT_PUBLIC_TRIAGE_GI_ENHANCED=1
NEXT_PUBLIC_EMOJI_MODE=legacy
NEXT_PUBLIC_PARTNER_FOOTER=1
NEXT_PUBLIC_SHOW_APP_CTA=0

# ==== Feature Flags P0 Optimizations ====
NEXT_PUBLIC_COPY_OVERHAUL=1
NEXT_PUBLIC_STICKY_CTA_GI=1
NEXT_PUBLIC_REPORT_ENHANCED=1
NEXT_PUBLIC_CTA_ORDER_DYNAMIC=1
# PDF_V2=1 # Removido - agora usando PDF unificado
PDF_UNIFIED=1 # Documental - sistema unificado ativo

# ==== URLs CTAs ====
NEXT_PUBLIC_URL_ZAPVIDA=/zapvida/atendimento
NEXT_PUBLIC_URL_ZAPFARM=/zapfarm/protocolos/digestivo

# ==== Partner URLs with UTMs ====
NEXT_PUBLIC_PARTNER_ZAPFARM_URL=https://zapfarm.com.br/?utm_source=zapfarm&utm_medium=cta&utm_campaign=gi
NEXT_PUBLIC_PARTNER_ZAPVIDA_URL=https://zapvida.com/?utm_source=zapfarm&utm_medium=cta&utm_campaign=gi
NEXT_PUBLIC_SHOW_PARTNER_CTAS=1

# ==== CRM Sink ====
CRM_SINK_URL=
CRM_SINK_TOKEN=

STRIPE_PRICE_ZAPFARM_MENSAL=price_xxx
STRIPE_PRICE_ZAPFARM_TRIMESTRAL=price_yyy
STRIPE_PRICE_ZAPFARM_SEMESTRAL=price_zzz
